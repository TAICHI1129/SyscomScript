class Main {
    run() {
        x = 7

        if (x >= 5 and x <= 10) {
            print("in range")
        }

        if (x != 0) {
            print("not zero")
        }

        if (not x == 0) {
            print("also not zero")
        }

        y = 3
        if (x > 5 or y > 5) {
            print("at least one is greater than 5")
        }
    }
}
